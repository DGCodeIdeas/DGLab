# DGLab PWA - Root Configuration

# Enable rewrite engine
RewriteEngine On

# Mask public directory - Redirect /public/anything to /anything
RewriteCond %{THE_REQUEST} /public/([^\s?]*) [NC]
RewriteRule ^public/(.*)$ /$1 [L,R=301]

# Block access to sensitive directories
RewriteRule ^(app|cli|config|database|docs|resources|routes|storage|tests|vendor)($|/) - [F,L,NC]
RewriteRule \.(env|example|lock|xml|yml|yaml|md|log|sql|zip)$ - [F,L,NC]

# Front controller - Route all requests to public/index.php
# We don't check for !-f or !-d because we want PHP to handle EVERYTHING,
# including existing files, to achieve "only ever physical access" to public/index.php
RewriteCond %{REQUEST_URI} !^/public/index\.php
RewriteRule ^(.*)$ public/index.php [QSA,L]

# Security headers (carried over from public/.htaccess)
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self'; media-src 'self'; frame-src 'none';"
</IfModule>

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml
</IfModule>

# Disable server signature
ServerSignature Off
