# DGLab PWA Environment Configuration
# Copy this file to .env and update with your actual values

# Application Settings
APP_NAME=DGLab
APP_ENV=development
APP_DEBUG=true
APP_URL=https://your-domain.com
APP_TIMEZONE=UTC

# Database Configuration (AeonFree MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=dglab_pwa
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Session Configuration
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# Cache Configuration
CACHE_DRIVER=file
CACHE_PREFIX=dglab_
CACHE_TTL=3600

# Security Settings
CSRF_TOKEN_LIFETIME=7200
PASSWORD_HASH_COST=10
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Upload Settings
MAX_UPLOAD_SIZE=52428800
CHUNK_SIZE=1048576
ALLOWED_EXTENSIONS=epub,txt,pdf

# PWA Settings
PWA_NAME=DGLab
PWA_SHORT_NAME=DGLab
PWA_THEME_COLOR=#0d6efd
PWA_BACKGROUND_COLOR=#ffffff
PWA_DISPLAY=standalone

# Logging
LOG_LEVEL=debug
LOG_CHANNEL=daily
LOG_MAX_FILES=7

# Rate Limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# Service Worker
SW_CACHE_VERSION=1.0.0
SW_OFFLINE_STRATEGY=cache-first
