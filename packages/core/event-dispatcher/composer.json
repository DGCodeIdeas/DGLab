{
    "name": "sovereign-stack/core-event-dispatcher",
    "description": "CORE-05: Production-ready PSR-14 Event Dispatcher with prioritized, haltable listener pipeline and lazy resolution",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "psr/event-dispatcher": "^1.0"
    },
    "suggest": {
        "psr/container": "^2.0 — for lazy listener resolution via DI container",
        "psr/log": "^3.0 — for error logging during dispatch"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10.5",
        "friendsofphp/php-cs-fixer": "^3.48"
    },
    "autoload": {
        "psr-4": {
            "SovereignStack\\Core\\EventDispatcher\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SovereignStack\\Core\\EventDispatcher\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}