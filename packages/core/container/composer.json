{
    "name": "sovereign-stack/core-container",
    "description": "CORE-02: PSR-11 compliant Dependency Injection Container with autowiring, compiler passes, and circular dependency detection",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "psr/container": "^2.0"
    },
    "suggest": {
        "psr/log": "^3.0 — for diagnostic logging during container compilation"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10.5",
        "friendsofphp/php-cs-fixer": "^3.48"
    },
    "autoload": {
        "psr-4": {
            "SovereignStack\\Core\\Container\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SovereignStack\\Core\\Container\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}