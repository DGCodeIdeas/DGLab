namespace {{ namespace }};

use DGLab\Tests\ComponentTestCase;

class {{ class }} extends ComponentTestCase
{
    public function test_it_renders_successfully()
    {
        $this->assertComponentRenders('{{ component }}');
    }

    public function test_it_renders_with_props()
    {
