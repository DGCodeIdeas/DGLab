{
    "name": "sovereign-stack/orchestrator",
    "description": "CORE-01: Polyrepo Orchestrator — Central PHP-driven automation tool for Sovereign Stack polyrepo lifecycle management",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "czproject/git-php": "^4.1",
        "php-http/discovery": "^1.19",
        "psr/http-message": "^2.0",
        "psr/http-factory": "^1.0",
        "psr/http-client": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^11.0",
        "friendsofphp/php-cs-fixer": "^3.64"
    },
    "autoload": {
        "psr-4": {
            "SovereignStack\\Orchestrator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SovereignStack\\Orchestrator\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/loom"
    ],
    "minimum-stability": "stable",
    "prefer-stable": true
}
