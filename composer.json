{
    "name": "dglab/pwa",
    "description": "DGLab Progressive Web App - Modular Service Architecture",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "DGLab Team",
            "email": "team@dglab.dev"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.0",
        "scssphp/scssphp": "^1.11",
        "twig/twig": "^3.0",
        "matthiasmullie/minify": "^1.3",
        "doctrine/dbal": "^3.0",
        "monolog/monolog": "^2.0",
        "psr/container": "^2.0",
        "psr/log": "^2.0"
    },
    "require-dev": {
        "phpspec/prophecy-phpunit": "^2.0",
        "phpstan/phpstan": "^1.0",
        "phpunit/phpunit": "^9.0",
        "squizlabs/php_codesniffer": "^3.7",
        "symfony/panther": "^2.4",
        "textalk/websocket": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "DGLab\\": "app/"
        },
        "files": [
            "app/Helpers/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "DGLab\\Tests\\": "tests/"
        }
    },
    "config": {
        "platform": {
            "php": "8.2.0"
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "cs": "vendor/bin/phpcs --standard=PSR12 app/",
        "analyse": "vendor/bin/phpstan analyse app/ --level=5",
        "migrate": "php cli/migrate.php",
        "deploy": "php cli/deploy.php"
    }
}
